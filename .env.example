# Скопируйте в .env и заполните
BOT_TOKEN=токен_бота_от_BotFather
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Эмбеддинги (этап 10) — через OpenRouter /embeddings
EMBEDDING_MODEL=google/gemini-embedding-001
EMBEDDING_DIM=3072
PGHOST=127.0.0.1
# pgvector-контейнер telewin-test-pg (:5434), отдельный от общего postgres16 (:5432)
PGPORT=5434
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=mydb
PGSCHEMA=telewin_test
REDIS_URL=redis://127.0.0.1:6379
PRICE_XLS=/путь/к/прайсу/2026-07-18T11-29-30.xls
# FTP-приём свежего прайса (этап 17). Пусто → работает только локальный PRICE_XLS.
# Наш приёмный vsftpd; поставщик заливает .xls раз в сутки в папку price. Пассивный режим.
PRICE_FTP_HOST=ftp_хост
PRICE_FTP_PORT=21
PRICE_FTP_USER=ftp_логин
PRICE_FTP_PASSWORD=
PRICE_FTP_DIR=price

# VK (этап 27) — community-токен сообщества + его числовой id. Пусто → канал выключен.
# Требуется Bots Long Poll API, включённый в настройках сообщества (события message_new).
VK_TOKEN=
VK_GROUP_ID=

# MAX (этап 28) — токен бота, передаётся заголовком Authorization (не query). Пусто → выключен.
MAX_TOKEN=
